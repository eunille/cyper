# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cybertutor

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters of random entropy
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Ollama (optional — only needed when LLM_PROVIDER=ollama) ─────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: cloudflare | groq | gemini | ollama
# RECOMMENDED: Cloudflare Workers AI — free 10k req/day, zero-retention policy
# Get keys: dash.cloudflare.com → Workers AI → Use REST API
LLM_PROVIDER=cloudflare
CF_ACCOUNT_ID=replace-with-cloudflare-account-id
CF_API_TOKEN=replace-with-cloudflare-api-token
CF_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Groq fallback (optional) — https://console.groq.com → API Keys
# LLM_PROVIDER=groq
GROQ_API_KEY=replace-with-your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini fallback (optional) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=replace-with-your-gemini-key
# GEMINI_MODEL=gemini-2.0-flash

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
